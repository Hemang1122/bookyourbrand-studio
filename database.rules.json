{
  "rules": {
    "status": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "users": {
      "$uid": {
        "connections": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        }
      }
    },
    "typing": {
      "$chatId": {
        ".read": "auth != null && root.child('chats/' + $chatId + '/participants/' + auth.uid).exists()",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isBoolean() || newData.val() === null"
        }
      }
    }
  }
}
