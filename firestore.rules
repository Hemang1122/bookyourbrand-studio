
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }
    
    function isAdminOrTeam() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (getUserData().role == 'admin' || getUserData().role == 'team');
    }

    function isParticipant(chatId) {
      return isSignedIn() &&
             request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId))
                 .data.participants;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isChatOwner(chatId) {
      return isSignedIn() && 
             (chatId.matches('^' + request.auth.uid + '_.*') || 
              chatId.matches('.*_' + request.auth.uid + '$') ||
              chatId.matches('.*_' + request.auth.uid + '_.*'));
    }

    // ── USERS COLLECTION ──────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }
    
    // ── CLIENTS COLLECTION ───────────────────────────────────
    match /clients/{clientId} {
      allow get: if isAdmin() || isOwner(clientId);
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(clientId);
      allow delete: if isAdmin();
    }

    match /clientDocuments/{documentId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || resource.data.clientId == request.auth.uid;
    }

    match /client-packages/{packageId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && 
                    (isAdmin() || resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── CHATS COLLECTION (Shared Support Support) ─────────────
    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || 
                    isChatOwner(chatId) || 
                    isParticipant(chatId) || 
                    resource.data.type == 'support';
      allow create: if isSignedIn() &&
                       (request.resource.data.createdBy == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || isParticipant(chatId));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, list: if isAdmin() || isChatOwner(chatId) || isParticipant(chatId);
        allow create: if isSignedIn() && (isAdmin() || isParticipant(chatId));
        allow update: if isSignedIn() && (isAdmin() || resource.data.senderId == request.auth.uid);
        allow delete: if isAdmin();
      }

      match /readReceipts/{userId} {
        allow read: if isAdmin() || isChatOwner(chatId) || isParticipant(chatId);
        allow write: if isSignedIn() && isOwner(userId);
      }
    }

    // ── PROJECTS COLLECTION ───────────────────────────────────
    match /projects/{projectId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
                    (
                      isAdmin() ||
                      resource.data.client.id == request.auth.uid ||
                      request.auth.uid in resource.data.team_ids
                    );
      allow create: if isSignedIn() &&
                       (
                         isAdmin() ||
                         request.resource.data.client.id == request.auth.uid
                       );
      allow update: if isSignedIn() &&
                       (
                         isAdmin() ||
                         resource.data.client.id == request.auth.uid ||
                         request.auth.uid in resource.data.team_ids
                       );
      allow delete: if isAdmin();

      match /chat-messages/{messageId} {
        function isProjectParticipant() {
          let projectData = get(/databases/$(database)/documents/projects/$(projectId)).data;
          return isAdmin() ||
                 request.auth.uid in projectData.team_ids ||
                 request.auth.uid == projectData.client.id;
        }
        
        allow read, list: if isSignedIn() && isProjectParticipant();
        
        allow create: if isSignedIn() && isProjectParticipant() &&
                         request.resource.data.senderId == request.auth.uid &&
                         (isAdmin() || getUserData().role == 'client');
        
        allow update: if isSignedIn() && isProjectParticipant() &&
                         request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['readBy', 'reactions']);
        
        allow delete: if isAdmin();
      }
    }

    // ── OTHER COLLECTIONS ───────────────────────────────────
    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow get, create, update, delete: if isSignedIn() &&
                                            (
                                              isAdmin() ||
                                              get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.client.id == request.auth.uid ||
                                              request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.team_ids
                                            );
    }

    match /files/{fileId} {
      allow list: if isSignedIn();
      allow get, create, update, delete: if isSignedIn() &&
                                            (
                                              isAdmin() ||
                                              get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.client.id == request.auth.uid ||
                                              request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.team_ids
                                            );
    }

    match /scrum-updates/{updateId} {
      allow list: if isAdminOrTeam();
      allow read: if isAdminOrTeam();
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /timer-sessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && 
                    (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
                     (
                       isAdmin() ||
                       request.auth.uid in resource.data.recipients
                     );
      allow update: if isSignedIn() &&
                       (
                         isAdmin() ||
                         request.auth.uid in resource.data.recipients
                       );
      allow delete: if isAdmin();
    }

    match /calls/{callId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow read: if isSignedIn() && 
                     (resource.data.callerId == request.auth.uid ||
                      resource.data.recipientId == request.auth.uid);
      allow update: if isSignedIn() &&
                       (resource.data.callerId == request.auth.uid ||
                        resource.data.recipientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && 
                    (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && 
                    (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
