/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and employs denormalized access control lists (ACLs) for collaborative resources like projects and files.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles.  Only the authenticated user can read/write their own profile.
 * - /projects/{projectId}: Stores project data. Access is controlled via a 'members' map on the project document, defining user roles (e.g., editor, viewer).
 * - /projects/{projectId}/tasks/{taskId}: Stores tasks associated with a project. Access inherits from the parent project's 'members' map.
 * - /projects/{projectId}/chat: Stores a single chat document associated with a project.
 * - /projects/{projectId}/chat/messages/{messageId}: Stores messages within a project's chat. Access inherits from the parent project's 'members' map.
 * - /projects/{projectId}/files/{fileId}: Stores file metadata. Access is controlled by the parent project's 'members' map.
 * - /roles_admin/{userId}: The existence of a document in this collection grants admin privileges to the user.
 *
 * Key Security Decisions:
 * - User listing is disabled to prevent enumeration.
 * - All write operations on collaborative resources (projects, files) require the user to be a member of the resource.
 * - Admin privileges are granted based on the presence of a document in the /roles_admin/{userId} collection.
 * - The ruleset prioritizes security and simplicity, foregoing complex data validation in favor of strict authorization checks.
 *
 * Denormalization for Authorization:
 * - Projects and Files: Include a `members` map (e.g., `{ members: { 'user_abc': 'editor' } }`) to avoid costly `get()` calls when checking permissions.
 * - Tasks: Inherit project-level access control.
 *
 * Structural Segregation:
 * - Private user data is stored under /users/{userId} to ensure easy, secure access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      //  Verified Identity
      function isSignedIn() {
        return request.auth != null;
      }
      // Access Control Pattern: Ownership
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId) && resource.data.id == userId;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Manages project data and access control through a members map.
     * @path /projects/{projectId}
     */
    match /projects/{projectId} {
      //  Verified Identity
      function isSignedIn() {
        return request.auth != null;
      }
      // Access Control Pattern: Shared Access (Closed Collaborators)
      function isProjectMember() {
        return resource.data.members[request.auth.uid] != null;
      }

      function isProjectEditor() {
        return resource.data.members[request.auth.uid] == 'editor';
      }

      function isProjectOwner() {
        return resource.data.members[request.auth.uid] == 'owner';
      }


      allow get, list: if isSignedIn() && isProjectMember();
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isSignedIn() && isProjectEditor();
      allow delete: if isSignedIn() && isProjectOwner();
    }

    /**
     * @description Manages tasks within a project, inheriting project-level access control.
     * @path /projects/{projectId}/tasks/{taskId}
     */
    match /projects/{projectId}/tasks/{taskId} {
      //  Verified Identity
      function isSignedIn() {
        return request.auth != null;
      }
      // Access Control Pattern: Shared Access (Closed Collaborators), inheritance from parent
      function isProjectMember() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      allow get, list: if isSignedIn() && isProjectMember();
      allow create: if isSignedIn() && isProjectMember();
      allow update: if isSignedIn() && isProjectMember();
      allow delete: if isSignedIn() && isProjectMember();
    }

     /**
      * @description Manages the single chat document associated with a project.
      * @path /projects/{projectId}/chat
      */
     match /projects/{projectId}/chat {
          //  Verified Identity
          function isSignedIn() {
            return request.auth != null;
          }
          // Access Control Pattern: Shared Access (Closed Collaborators), inheritance from parent
          function isProjectMember() {
            return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
          }

          allow get, list: if isSignedIn() && isProjectMember();
          allow create: if isSignedIn() && isProjectMember();
          allow update: if isSignedIn() && isProjectMember();
          allow delete: if isSignedIn() && isProjectMember();
     }


    /**
     * @description Manages messages within a project's chat, inheriting project-level access control.
     * @path /projects/{projectId}/chat/messages/{messageId}
     */
    match /projects/{projectId}/chat/messages/{messageId} {
      //  Verified Identity
      function isSignedIn() {
        return request.auth != null;
      }
      // Access Control Pattern: Shared Access (Closed Collaborators), inheritance from parent
      function isProjectMember() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }


      allow get, list: if isSignedIn() && isProjectMember();
      allow create: if isSignedIn() && isProjectMember();
      allow update: if isSignedIn() && isProjectMember();
      allow delete: if isSignedIn() && isProjectMember();
    }

    /**
     * @description Manages files uploaded to a project, using project membership for access control.
     * @path /projects/{projectId}/files/{fileId}
     */
    match /projects/{projectId}/files/{fileId} {
      //  Verified Identity
      function isSignedIn() {
        return request.auth != null;
      }
      // Access Control Pattern: Shared Access (Closed Collaborators), inheritance from parent
      function isProjectMember() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      allow get, list: if isSignedIn() && isProjectMember();
      allow create: if isSignedIn() && isProjectMember();
      allow update: if isSignedIn() && isProjectMember();
      allow delete: if isSignedIn() && isProjectMember();
    }

     /**
      * @description Grants admin privileges based on the existence of a document in this collection.
      * @path /roles_admin/{userId}
      */
     match /roles_admin/{userId} {
          //  Verified Identity
          function isSignedIn() {
            return request.auth != null;
          }
          // Access Control Pattern: Ownership
          function isOwner(userId) {
            return request.auth.uid == userId;
          }

          allow get: if isSignedIn() && isOwner(userId);
          allow list: if false;
          allow create: if isSignedIn() && isOwner(userId);
          allow update: if isSignedIn() && isOwner(userId);
          allow delete: if isSignedIn() && isOwner(userId);
     }
  }
}