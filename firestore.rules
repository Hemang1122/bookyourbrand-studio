
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
       allow read, write: if isSignedIn();
    }

    match /files/{fileId} {
        allow read, write: if isSignedIn();
    }

    match /scrum-updates/{updateId} {
        allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
        // A user can read a notification if their UID is in the recipients list.
        // This works for 'array-contains' queries on the 'recipients' field.
        allow read: if isSignedIn() && request.auth.uid in resource.data.recipients;

        // Notifications are created by the system (via DataProvider), not directly by clients.
        // Writes should be handled by more specific rules if client-side updates are ever needed.
        allow write: if false;
    }
  }
}
