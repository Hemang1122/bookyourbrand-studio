/**
 * @fileoverview Firestore Security Rules for BookYourBrands CRM.
 *
 * Core Philosophy:
 * This ruleset enforces a strict hierarchical ownership model, primarily based on
 * path-based authorization, where data access is determined by the document's
 * location within the Firestore collection structure.  It avoids using `get()`
 * calls in security rules, favoring path-based authorization instead for efficiency
 * and security.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, accessible only by the user themselves.
 * - /clients/{clientId}/projects/{projectId}: Stores projects nested under clients, enforcing client-project relationships.
 * - /clients/{clientId}/projects/{projectId}/tasks/{taskId}: Stores tasks nested under projects, further enforcing client-project-task relationships.
 * - /projects/{projectId}/chats/{chatId}: Stores chats related to specific projects.
 * - /projects/{projectId}/chats/{chatId}/messages/{messageId}: Stores messages within chats.
 * - /projects/{projectId}/files/{fileId}: Stores files associated with projects.
 *
 * Key Security Decisions:
 * - User listing is denied to prevent unauthorized data enumeration.
 * - Path-based authorization is favored to avoid costly and complex `get()` calls.
 * - Data validation during write operations is limited to relational integrity and
 *   authorization-critical fields for prototyping flexibility.
 * - All write operations are protected by authorization checks to prevent unauthorized modifications.
 *
 * Denormalization for Authorization:
 *  - Path-based rules inherently denormalize the relationships between entities,
 *    allowing rules to directly enforce access control based on document location
 *    without needing to read related documents.
 *
 * Structural Segregation:
 *  - The nested structure of collections (e.g., projects under clients) inherently
 *    segregates data based on relationships, allowing for clear and enforceable
 *    security boundaries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a user to read and write their own user document.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own document with matching ID.
     * @allow (get) User with ID 'user123' can read their own document.
     * @allow (update) User with ID 'user123' can update their own document.
     * @allow (delete) User with ID 'user123' can delete their own document.
     * @deny (create) User with ID 'user123' cannot create a document with ID 'user456'.
     * @deny (get) User with ID 'user123' cannot read document with ID 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows creating, reading, updating, and deleting projects under a specific client by authenticated users.
     * @path /clients/{clientId}/projects/{projectId}
     * @allow (create) Authenticated user can create a project under a client.
     * @allow (get) Authenticated user can read a project under a client.
     * @allow (update) Authenticated user can update a project under a client.
     * @allow (delete) Authenticated user can delete a project under a client.
     * @deny (create) Unauthenticated user cannot create a project.
     * @deny (get) Unauthenticated user cannot read a project.
     * @principle Enforces that only authenticated users can manage projects under clients.
     */
    match /clients/{clientId}/projects/{projectId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows creating, reading, updating, and deleting tasks under a specific project by authenticated users.
     * @path /clients/{clientId}/projects/{projectId}/tasks/{taskId}
     * @allow (create) Authenticated user can create a task under a project.
     * @allow (get) Authenticated user can read a task under a project.
     * @allow (update) Authenticated user can update a task under a project.
     * @allow (delete) Authenticated user can delete a task under a project.
     * @deny (create) Unauthenticated user cannot create a task.
     * @deny (get) Unauthenticated user cannot read a task.
     * @principle Enforces that only authenticated users can manage tasks under projects.
     */
    match /clients/{clientId}/projects/{projectId}/tasks/{taskId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows creating, reading, updating, and deleting chats under a specific project by authenticated users.
     * @path /projects/{projectId}/chats/{chatId}
     * @allow (create) Authenticated user can create a chat under a project.
     * @allow (get) Authenticated user can read a chat under a project.
     * @allow (update) Authenticated user can update a chat under a project.
     * @allow (delete) Authenticated user can delete a chat under a project.
     * @deny (create) Unauthenticated user cannot create a chat.
     * @deny (get) Unauthenticated user cannot read a chat.
     * @principle Enforces that only authenticated users can manage chats under projects.
     */
    match /projects/{projectId}/chats/{chatId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows creating, reading, updating, and deleting messages under a specific chat by authenticated users.
     * @path /projects/{projectId}/chats/{chatId}/messages/{messageId}
     * @allow (create) Authenticated user can create a message under a chat.
     * @allow (get) Authenticated user can read a message under a chat.
     * @allow (update) Authenticated user can update a message under a chat.
     * @allow (delete) Authenticated user can delete a message under a chat.
     * @deny (create) Unauthenticated user cannot create a message.
     * @deny (get) Unauthenticated user cannot read a message.
     * @principle Enforces that only authenticated users can manage messages under chats.
     */
    match /projects/{projectId}/chats/{chatId}/messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows creating, reading, updating, and deleting files under a specific project by authenticated users.
     * @path /projects/{projectId}/files/{fileId}
     * @allow (create) Authenticated user can create a file under a project.
     * @allow (get) Authenticated user can read a file under a project.
     * @allow (update) Authenticated user can update a file under a project.
     * @allow (delete) Authenticated user can delete a file under a project.
     * @deny (create) Unauthenticated user cannot create a file.
     * @deny (get) Unauthenticated user cannot read a file.
     * @principle Enforces that only authenticated users can manage files under projects.
     */
    match /projects/{projectId}/files/{fileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}