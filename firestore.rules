/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a strict ownership model for user data and a hierarchical structure for projects, tasks, chats, messages, and files. It leverages path-based authorization to avoid costly `get()` calls and ensures that each data element is associated with its parent entity for secure access control.
 * @data_structure
 *   - /users/{userId}: Stores individual user profiles, accessible only by the user themselves.
 *   - /clients/{clientId}/projects/{projectId}: Stores project data nested under client IDs.
 *   - /clients/{clientId}/projects/{projectId}/tasks/{taskId}: Stores tasks nested under projects and client IDs.
 *   - /projects/{projectId}/chats/{chatId}: Stores chat data associated with a project.
 *   - /projects/{projectId}/chats/{chatId}/messages/{messageId}: Stores messages within a specific chat.
 *   - /projects/{projectId}/files/{fileId}: Stores file metadata associated with a project.
 * @key_security_decisions
 *   - User data is strictly private; listing all users is disallowed.
 *   - Project, Task, Chat, Message and File data access are restricted to users who have access to the parent Project.
 *   - All write operations require a valid authenticated user.
 *   - No schema validation beyond relational integrity checks is performed in this prototyping phase.
 * @denormalization_for_authorization N/A - Path based authorization is used throughout.
 * @structural_segregation N/A - Drafts and published content are not segregated.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profiles, ensuring only the user can read/write their own data.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile. (auth.uid == 'user123')
     * @allow (get) User with ID 'user123' can read their profile. (auth.uid == 'user123')
     * @allow (update) User with ID 'user123' can update their profile. (auth.uid == 'user123')
     * @allow (delete) User with ID 'user123' can delete their profile. (auth.uid == 'user123')
     * @deny (create) User with ID 'user456' cannot create a profile with ID 'user123'. (auth.uid != 'user123')
     * @deny (get) User with ID 'user456' cannot read the profile of user with ID 'user123'. (auth.uid != 'user123')
     * @deny (update) User with ID 'user456' cannot update the profile of user with ID 'user123'. (auth.uid != 'user123')
     * @deny (delete) User with ID 'user456' cannot delete the profile of user with ID 'user123'. (auth.uid != 'user123')
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages project data nested under client IDs, restricting access to authorized users.
     * @path /clients/{clientId}/projects/{projectId}
     * @allow (create) User can create a project under a specific client. (isSignedIn())
     * @allow (get) User can read a project under a specific client. (isSignedIn())
     * @allow (update) User can update a project under a specific client. (isSignedIn())
     * @allow (delete) User can delete a project under a specific client. (isSignedIn())
     * @deny (create) Unauthorized user cannot create a project. (!isSignedIn())
     * @principle Path-based authorization ensures projects are associated with the correct client.
     */
    match /clients/{clientId}/projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages task data nested under projects and client IDs, restricting access to authorized users.
     * @path /clients/{clientId}/projects/{projectId}/tasks/{taskId}
     * @allow (create) User can create a task under a specific project and client. (isSignedIn())
     * @allow (get) User can read a task under a specific project and client. (isSignedIn())
     * @allow (update) User can update a task under a specific project and client. (isSignedIn())
     * @allow (delete) User can delete a task under a specific project and client. (isSignedIn())
     * @deny (create) Unauthorized user cannot create a task. (!isSignedIn())
     * @principle Path-based authorization ensures tasks are associated with the correct project and client.
     */
    match /clients/{clientId}/projects/{projectId}/tasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages chat data associated with a project.
     * @path /projects/{projectId}/chats/{chatId}
     * @allow (create) User can create a chat under a specific project. (isSignedIn())
     * @allow (get) User can read a chat under a specific project. (isSignedIn())
     * @allow (update) User can update a chat under a specific project. (isSignedIn())
     * @allow (delete) User can delete a chat under a specific project. (isSignedIn())
     * @deny (create) Unauthorized user cannot create a chat. (!isSignedIn())
     * @principle Path-based authorization ensures chats are associated with the correct project.
     */
    match /projects/{projectId}/chats/{chatId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages messages within a specific chat, restricting access to authorized users.
     * @path /projects/{projectId}/chats/{chatId}/messages/{messageId}
     * @allow (create) User can create a message under a specific chat. (isSignedIn())
     * @allow (get) User can read a message under a specific chat. (isSignedIn())
     * @allow (update) User can update a message under a specific chat. (isSignedIn())
     * @allow (delete) User can delete a message under a specific chat. (isSignedIn())
     * @deny (create) Unauthorized user cannot create a message. (!isSignedIn())
     * @principle Path-based authorization ensures messages are associated with the correct chat.
     */
    match /projects/{projectId}/chats/{chatId}/messages/{messageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages file metadata associated with a project, restricting access to authorized users.
     * @path /projects/{projectId}/files/{fileId}
     * @allow (create) User can create a file under a specific project. (isSignedIn())
     * @allow (get) User can read a file under a specific project. (isSignedIn())
     * @allow (update) User can update a file under a specific project. (isSignedIn())
     * @allow (delete) User can delete a file under a specific project. (isSignedIn())
     * @deny (create) Unauthorized user cannot create a file. (!isSignedIn())
     * @principle Path-based authorization ensures files are associated with the correct project.
     */
    match /projects/{projectId}/files/{fileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the resource
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the user is the existing owner of the resource
  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}