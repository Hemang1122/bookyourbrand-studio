/**
 * @file Firestore Security Rules
 * @description This ruleset enforces role-based access control (admin, team, client) for a CRM system,
 *              with a focus on user-owned data and collaborative projects. Data is organized into
 *              top-level collections for users, projects, tasks, chats, messages, and files.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure access based on user roles and project memberships.
 * It leverages denormalized data within documents to avoid costly `get()` operations in security rules.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Accessible only to the user and admins.
 * - /projects/{projectId}: Stores project data. Access is controlled via a `members` map
 *   within the document, defining user roles (admin, team, client) for the project.
 * - /tasks/{taskId}: Stores task data. Access is granted to users assigned to the task.
 * - /chats/{chatId}: Stores chat room data. 'chatId' is the same as 'projectId', enabling easy association.
 * - /chats/{chatId}/messages/{messageId}: Stores chat messages. Access controlled by project membership.
 * - /files/{fileId}: Stores file metadata. Access is controlled by project membership and uploader.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user documents.
 * - Projects utilize a `members` map for role-based access control.
 * - Listing of user documents is forbidden to prevent information disclosure.
 * - All write operations validate the existence of the document to prevent accidental damage.
 *
 * Denormalization for Authorization:
 * The `Project` documents contain a `members` map (e.g., `{ members: { 'user_abc': 'editor' } }`) to
 * define user roles within the project. This denormalization avoids the need for complex queries
 * or `get()` operations to determine a user's access rights to a project and its related data
 * (tasks, chats, files).
 *
 * Structural Segregation:
 * User profiles are stored in a dedicated `/users/{userId}` collection, separate from other data,
 * to ensure clear ownership and access control. Project-related data (tasks, chats, files) is stored
 * in top-level collections, and access is controlled based on project membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile data. Only the user and admins can access their own profile.
     * @path /users/{userId}
     * @allow (create) - User with ID 'user123' can create their profile if request.auth.uid == 'user123'.
     * @allow (get, update, delete) - User with ID 'user123' can access/modify their profile if request.auth.uid == 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a profile with ID 'user123'.
     * @deny (get, update, delete) - User with ID 'user456' cannot access/modify profile 'user123'.
     * @principle Enforces document ownership for user profiles and ensures that user IDs match the authenticated user ID.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId));
      }

      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not allowed.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages project data. Access is controlled via a `members` map within the document.
     * @path /projects/{projectId}
     * @allow (get, list) - Any authenticated user can view project if they are in the `members` map.
     * @allow (create) - User can create a project if they are the project creator.
     * @allow (update, delete) - Only project admins (defined in `members` map) can update/delete the project.
     * @deny (create) - User cannot create a project without being authenticated.
     * @deny (update, delete) - User cannot update/delete a project if they are not an admin in the `members` map.
     * @principle Enforces role-based access control using the `members` map for collaborative projects.
     */
    match /projects/{projectId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getProjectRole(projectId) {
          return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid];
      }

      function isProjectMember(projectId) {
        return isSignedIn() && getProjectRole(projectId) != null;
      }

      function isProjectAdmin(projectId) {
          return isSignedIn() && getProjectRole(projectId) == 'admin';
      }

      function isExistingProjectAdmin(projectId) {
          return isProjectAdmin(projectId) && existsAfter(/databases/$(database)/documents/projects/$(projectId));
      }

      allow get, list: if isProjectMember(projectId);
      allow create: if isSignedIn(); // Further validation in the function below to check user role.
      allow update: if isExistingProjectAdmin(projectId);
      allow delete: if isExistingProjectAdmin(projectId);
    }

    /**
     * @description Manages task data. Access is granted to assigned users and project members.
     * @path /tasks/{taskId}
     * @allow (get, list) - Any authenticated user can view task if they are assigned to or are a member of the project.
     * @allow (create) - User can create a task if they are a member of the project.
     * @allow (update, delete) - Only project admins (defined in `members` map) can update/delete the task.
     * @deny (create) - User cannot create a task without being a member of the project.
     * @deny (update, delete) - User cannot update/delete a task if they are not an admin in the `members` map.
     * @principle Enforces role-based access control and task assignment for collaborative projects.
     */
    match /tasks/{taskId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getProjectRoleByTask(taskId) {
          let projectID = resource.data.projectId;
          return get(/databases/$(database)/documents/projects/$(projectID)).data.members[request.auth.uid];
      }

      function isTaskAssignedUser(taskId) {
        return request.auth.uid == resource.data.assignedTo;
      }

      function isTaskProjectMember(taskId) {
          return isSignedIn() && getProjectRoleByTask(taskId) != null;
      }

      function isTaskProjectAdmin(taskId) {
          return isSignedIn() && getProjectRoleByTask(taskId) == 'admin';
      }

      function isExistingTaskProjectAdmin(taskId) {
          return isTaskProjectAdmin(taskId) && existsAfter(/databases/$(database)/documents/tasks/$(taskId));
      }


      allow get, list: if isTaskAssignedUser(taskId) || isTaskProjectMember(taskId);
      allow create: if isTaskProjectMember(taskId);
      allow update: if isExistingTaskProjectAdmin(taskId);
      allow delete: if isExistingTaskProjectAdmin(taskId);
    }

    /**
     * @description Manages chat room data. The 'chatId' matches the 'projectId'.
     * @path /chats/{chatId}
     * @allow (get, list) - Any authenticated user can view chat if they are a member of the project.
     * @allow (create) - User can create a chat if they are a member of the project.
     * @allow (update, delete) - No updates or deletes are permitted on chats.
     * @deny (create) - User cannot create a chat without being a member of the project.
     * @deny (update, delete) - No one can update or delete a chat.
     * @principle Enforces access control to chat rooms based on project membership.
     */
    match /chats/{chatId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getProjectRoleByChat(chatId) {
          return get(/databases/$(database)/documents/projects/$(chatId)).data.members[request.auth.uid];
      }

      function isChatProjectMember(chatId) {
          return isSignedIn() && getProjectRoleByChat(chatId) != null;
      }

      allow get, list: if isChatProjectMember(chatId);
      allow create: if isChatProjectMember(chatId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages messages within a chat room. Access is controlled by project membership.
     * @path /chats/{chatId}/messages/{messageId}
     * @allow (get, list) - Any authenticated user can view message if they are a member of the project.
     * @allow (create) - User can create a message if they are a member of the project.
     * @allow (update, delete) - No updates or deletes are permitted on messages.
     * @deny (create) - User cannot create a message without being a member of the project.
     * @deny (update, delete) - No one can update or delete a message.
     * @principle Enforces access control to chat messages based on project membership.
     */
    match /chats/{chatId}/messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getProjectRoleByMessage(chatId) {
          let chatDocument = get(/databases/$(database)/documents/chats/$(chatId));
          return chatDocument.data.members[request.auth.uid];
      }

      function isMessageProjectMember(chatId) {
          return isSignedIn() && getProjectRoleByMessage(chatId) != null;
      }

      allow get, list: if isMessageProjectMember(chatId);
      allow create: if isMessageProjectMember(chatId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages file metadata. Access is controlled by project membership and uploader.
     * @path /files/{fileId}
     * @allow (get, list) - Any authenticated user can view file if they are a member of the project or the uploader.
     * @allow (create) - User can create a file if they are a member of the project.
     * @allow (update, delete) - Only project admins (defined in `members` map) can update/delete the file.
     * @deny (create) - User cannot create a file without being a member of the project.
     * @deny (update, delete) - User cannot update/delete a file if they are not an admin in the `members` map.
     * @principle Enforces role-based access control and uploader permissions for file management within projects.
     */
    match /files/{fileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getProjectRoleByFile(fileId) {
          let projectID = resource.data.projectId;
          return get(/databases/$(database)/documents/projects/$(projectID)).data.members[request.auth.uid];
      }

      function isFileUploader(fileId) {
        return request.auth.uid == resource.data.uploadedBy;
      }

      function isFileProjectMember(fileId) {
          return isSignedIn() && getProjectRoleByFile(fileId) != null;
      }

      function isFileProjectAdmin(fileId) {
          return isSignedIn() && getProjectRoleByFile(fileId) == 'admin';
      }

      function isExistingFileProjectAdmin(fileId) {
          return isFileProjectAdmin(fileId) && existsAfter(/databases/$(database)/documents/files/$(fileId));
      }

      allow get, list: if isFileUploader(fileId) || isFileProjectMember(fileId);
      allow create: if isFileProjectMember(fileId);
      allow update: if isExistingFileProjectAdmin(fileId);
      allow delete: if isExistingFileProjectAdmin(fileId);
    }
  }
}