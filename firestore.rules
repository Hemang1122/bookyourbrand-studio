
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* -------------------- Helper Functions -------------------- */
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isProjectMember(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      let userId = request.auth.uid;

      return isAdmin()
        || project.client.id == userId
        || (project.team_ids != null && userId in project.team_ids);
    }

    /* -------------------- USERS -------------------- */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /* -------------------- CLIENTS -------------------- */
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* -------------------- PROJECTS -------------------- */
    match /projects/{projectId} {
      // Allow listing all projects
      allow list: if isSignedIn();

      // Allow reading single document
      allow get: if isProjectMember(projectId);

      // Creating new projects
      allow create: if isSignedIn();

      // Updating / deleting projects
      allow update, delete: if isProjectMember(projectId);
    }

    /* -------------------- TASKS -------------------- */
    match /tasks/{taskId} {
      allow read, write, list: if isSignedIn();
    }

    /* -------------------- FILES -------------------- */
    match /files/{fileId} {
      allow read, write, list: if isSignedIn();
    }

    /* -------------------- SCRUM UPDATES -------------------- */
    match /scrum-updates/{updateId} {
      allow read, write, list: if isSignedIn();
    }

    /* -------------------- NOTIFICATIONS -------------------- */
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.recipients;
      allow update, delete: if false;
    }

    /* -------------------- MESSAGES -------------------- */
    match /messages/{messageId} {

      // Allow querying messages by projectId
      allow list: if isSignedIn()
        && request.query.projectId != null
        && isProjectMember(request.query.projectId);

      // Reading single message
      allow get: if isSignedIn()
        && isProjectMember(resource.data.projectId);

      // Creating/Editing messages
      allow create, update, delete: if isSignedIn()
        && isProjectMember(request.resource.data.projectId);
    }
  }
}
