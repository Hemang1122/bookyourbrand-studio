/**
 * @file Firestore Security Rules for BookYourBrands CRM
 *
 * @core_philosophy This ruleset enforces a project-centric security model. Users gain access to
 *   project-related data (tasks, chats, files) based on their membership in the project.
 *   User data is strictly owned and controlled by the individual user.
 *
 * @data_structure
 *   - /users/{userId}: Stores personal user data, accessible only to the user themselves.
 *   - /projects/{projectId}: Stores project metadata and access control lists (members map).
 *   - /projects/{projectId}/tasks/{taskId}: Stores project tasks. Access is determined by
 *     membership in the parent project.
 *   - /projects/{projectId}/chats/{chatId}: Stores chat metadata for a project. Access is
 *     determined by membership in the parent project. The `chatId` should ideally match the `projectId`.
 *   - /projects/{projectId}/chats/{chatId}/messages/{messageId}: Stores individual chat messages.
 *     Access is determined by membership in the parent project.
 *   - /projects/{projectId}/files/{fileId}: Stores file metadata for a project. Access is
 *     determined by membership in the parent project.
 *
 * @key_security_decisions
 *   - User data is private and only accessible to the user.
 *   - Project access is managed through a `members` map on the project document. This map
 *     defines the roles of different users within the project.
 *   - Listing of users is not allowed to prevent information disclosure.
 *   - Subcollections inherit access control from their parent project document, ensuring
 *     consistent authorization.
 *
 * @denormalization_for_authorization
 *   - Project membership (`members` map) is denormalized into subcollections (tasks, chats, files) to avoid costly `get()` calls and enable simpler security rules.
 *
 * @structural_segregation
 *   - Private user data is stored under `/users/{userId}`, while project data is stored
 *     under `/projects/{projectId}`, ensuring clear separation of access control concerns.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user documents. Only the authenticated user can read, update, or delete their own document.
     * @path /users/{userId}
     * @allow (create) - User with ID 'user123' can create their own document when authenticated as 'user123'.
     * @allow (get, update, delete) - User with ID 'user123' can get, update, and delete their own document when authenticated as 'user123'.
     * @deny (create) - User with ID 'user123' cannot create a document with ID 'user456'.
     * @deny (get, update, delete) - User with ID 'user123' cannot get, update, or delete the document with ID 'user456'.
     * @deny (list) - No one is allowed to list all users.
     * @principle Enforces document ownership for user data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to project documents. Access is based on project membership defined in the 'members' map.
     * @path /projects/{projectId}
     * @allow (get, list) - Any authenticated user can get and list projects.
     * @allow (create) - Any authenticated user can create a project.  MUST set the `clientId` field to ensure relational integrity.
     * @allow (update, delete) - Only project members with 'editor' role can update or delete the project.
     * @deny (create) - Unauthenticated users cannot create projects.
     * @deny (update, delete) - Users without 'editor' role in the project cannot update or delete it.
     * @principle Enforces project-based access control using a 'members' map.
     */
    match /projects/{projectId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProjectMember() {
        return isSignedIn() && resource.data.members[request.auth.uid] != null;
      }

      function isProjectEditor() {
        return isSignedIn() && resource.data.members[request.auth.uid] == 'editor';
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clientId is string;
      allow update: if isProjectEditor();
      allow delete: if isProjectEditor();
    }

    /**
     * @description Controls access to tasks within a project. Access is inherited from the parent project's membership.
     * @path /projects/{projectId}/tasks/{taskId}
     * @allow (get, list) - Any project member can get and list tasks.
     * @allow (create) - Any project member can create a task. MUST set the `projectId` field to ensure relational integrity.
     * @allow (update, delete) - Only project members with 'editor' role can update or delete tasks.
     * @deny (create) - Unauthenticated users cannot create tasks.
     * @deny (update, delete) - Users without 'editor' role in the project cannot update or delete tasks.
     * @principle Enforces project-based access control for tasks, inheriting membership.
     */
    match /projects/{projectId}/tasks/{taskId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProjectMember(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      function isProjectEditor(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] == 'editor';
      }

      allow get, list: if isProjectMember(projectId);
      allow create: if isProjectMember(projectId) && request.resource.data.projectId == projectId;
      allow update: if isProjectEditor(projectId);
      allow delete: if isProjectEditor(projectId);
    }

    /**
     * @description Controls access to chats within a project. Access is inherited from the parent project's membership.
     * @path /projects/{projectId}/chats/{chatId}
     * @allow (get, list) - Any project member can get and list chats.
     * @allow (create) - Any project member can create a chat. MUST set the `projectId` field to ensure relational integrity.
     * @allow (update, delete) - Only project members with 'editor' role can update or delete chats.
     * @deny (create) - Unauthenticated users cannot create chats.
     * @deny (update, delete) - Users without 'editor' role in the project cannot update or delete chats.
     * @principle Enforces project-based access control for chats, inheriting membership.
     */
    match /projects/{projectId}/chats/{chatId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProjectMember(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      function isProjectEditor(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] == 'editor';
      }

      allow get, list: if isProjectMember(projectId);
      allow create: if isProjectMember(projectId) && request.resource.data.projectId == projectId;
      allow update: if isProjectEditor(projectId);
      allow delete: if isProjectEditor(projectId);
    }

    /**
     * @description Controls access to messages within a chat. Access is based on project membership.
     * @path /projects/{projectId}/chats/{chatId}/messages/{messageId}
     * @allow (get, list) - Any project member can get and list messages.
     * @allow (create) - Any project member can create a message. MUST set the `chatId` and `senderId` field to ensure relational integrity.
     * @allow (update, delete) - No one can update or delete messages.
     * @deny (create) - Unauthenticated users cannot create messages.
     * @deny (update, delete) - No one can update or delete messages.
     * @principle Enforces project-based access control for messages, inheriting membership.
     */
    match /projects/{projectId}/chats/{chatId}/messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProjectMember(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      allow get, list: if isProjectMember(projectId);
      allow create: if isProjectMember(projectId) && request.resource.data.chatId == chatId && request.resource.data.senderId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to files within a project. Access is inherited from the parent project's membership.
     * @path /projects/{projectId}/files/{fileId}
     * @allow (get, list) - Any project member can get and list files.
     * @allow (create) - Any project member can create a file. MUST set the `projectId` and `uploadedBy` field to ensure relational integrity.
     * @allow (update, delete) - Only project members with 'editor' role can update or delete files.
     * @deny (create) - Unauthenticated users cannot create files.
     * @deny (update, delete) - Users without 'editor' role in the project cannot update or delete files.
     * @principle Enforces project-based access control for files, inheriting membership.
     */
    match /projects/{projectId}/files/{fileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProjectMember(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

       function isProjectEditor(projectId) {
        return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] == 'editor';
      }

      allow get, list: if isProjectMember(projectId);
      allow create: if isProjectMember(projectId) && request.resource.data.projectId == projectId && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isProjectEditor(projectId);
      allow delete: if isProjectEditor(projectId);
    }
  }
}