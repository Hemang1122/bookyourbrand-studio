/**
 * @file Firebase Security Rules for BookYourBrands CRM
 *
 * @core_philosophy This ruleset enforces a user-ownership model for user profiles
 * and a shared access model for projects and their associated data (tasks, chats, files).
 * It prioritizes security by default, requiring explicit rules for each operation.
 *
 * @data_structure
 * - /users/{userId}: Stores individual user profiles. Only the authenticated user can
 *   read or write their own profile.
 * - /projects/{projectId}: Stores project data. Access is controlled by a `members` map
 *   on the project document, where keys are user UIDs and values are roles.
 * - /projects/{projectId}/tasks/{taskId}: Stores tasks associated with projects. Access
 *   is inherited from the parent project's `members` map.
 * - /projects/{projectId}/chats/{chatId}: Stores chat data for projects. Access is
 *   inherited from the parent project's `members` map.
 * - /projects/{projectId}/chats/{chatId}/messages/{messageId}: Stores individual messages
 *   within a chat. Access is governed by the parent chat's (and thus project's) `members` map.
 * - /projects/{projectId}/files/{fileId}: Stores files related to projects. Access is
 *   inherited from the parent project's `members` map.
 *
 * @key_security_decisions
 * - User listing is disallowed to protect user privacy.
 * - All write operations require authentication (`request.auth != null`).
 * - Data validation is relaxed in this prototype to allow for flexible schema evolution,
 *   but authorization-critical fields (e.g., ownership, member lists) are validated.
 * - To enhance security and performance, data required for authorization (e.g., project
 *   member lists) is denormalized onto child documents.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles. Only the authenticated user can manage their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creating their own profile.
     *   Request: auth.uid = "user123", resource.data.id = "user123"
     * @allow (get) - Authenticated user reading their own profile.
     *   Request: auth.uid = "user123", path = "/databases/(default)/documents/users/user123"
     * @allow (update) - Authenticated user updating their own profile.
     *   Request: auth.uid = "user123", path = "/databases/(default)/documents/users/user123"
     * @allow (delete) - Authenticated user deleting their own profile.
     *   Request: auth.uid = "user123", path = "/databases/(default)/documents/users/user123"
     * @deny (get) - Any user trying to read another user's profile.
     *   Request: auth.uid = "user456", path = "/databases/(default)/documents/users/user123"
     * @deny (create) - User attempts to create a profile with an ID different from their own auth.uid.
     *   Request: auth.uid = "user123", resource.data.id = "user456"
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in and owns the resource.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allow the user to create their own profile if the userId matches their auth.uid.
      allow create: if isOwner(userId) && request.resource.data.get('id', '') == request.auth.uid;

      // Allow the user to read their own profile.
      allow get: if isOwner(userId);

      // Allow the user to update their own profile. Enforce immutability of userId.
      allow update: if isOwner(userId) && request.resource.data.get('id', '') == request.auth.uid;

      // Allow the user to delete their own profile.
      allow delete: if isOwner(userId); // Ensure the document exists

      // Prevent listing of all users.
      allow list: if false;
    }

    /**
     * @description Secure projects. Access is controlled by the 'members' map on the project document.
     * @path /projects/{projectId}
     * @allow (create) - Authenticated user creating a project.
     *   Request: auth.uid = "user123", resource.data.members["user123"] exists
     * @allow (get) - Authenticated user reading a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (update) - Authenticated user updating a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "editor"
     * @allow (delete) - Authenticated user deleting a project they own.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "owner"
     * @deny (create) - Unauthenticated user attempting to create a project.
     *   Request: auth.uid = null
     * @deny (get) - User attempting to read a project they are not a member of.
     *   Request: auth.uid = "user456", project.data.members["user456"] does not exist
     * @principle Enforces shared access through membership maps.
     */
    match /projects/{projectId} {
      // Helper function to check if the user is a member of the project.
      function isProjectMember() {
        return request.auth != null && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }

      // Helper function to check if the user has a specific role within the project.
      function hasProjectRole(role) {
        return request.auth != null && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] == role;
      }
      
      // Helper function to check if the user is an existing member of the project.
      function isExistingProjectMember() {
        return request.auth != null && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] != null;
      }
      
      // Helper function to check if the user has a specific role within the project and document exists.
      function hasExistingProjectRole(role) {
        return request.auth != null && get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid] == role;
      }

      // Allow creating a project if the user is authenticated and has a role in the project.
      allow create: if request.auth != null && request.resource.data.members[request.auth.uid] != null;

      // Allow reading a project if the user is a member.
      allow get: if isProjectMember();

      // Allow updating a project if the user is an editor.
      allow update: if isProjectMember();

      // Allow deleting a project if the user is the owner.
      allow delete: if hasProjectRole('owner');

      // Allow listing all projects.
      allow list: if true;
    }

    /**
     * @description Secure tasks within a project. Access is inherited from the parent project's 'members' map.
     * @path /projects/{projectId}/tasks/{taskId}
     * @allow (create) - Authenticated user creating a task in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (get) - Authenticated user reading a task in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (update) - Authenticated user updating a task in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "editor"
     * @allow (delete) - Authenticated user deleting a task in a project they own.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "owner"
     * @deny (create) - Unauthenticated user attempting to create a task.
     *   Request: auth.uid = null
     * @deny (get) - User attempting to read a task in a project they are not a member of.
     *   Request: auth.uid = "user456", project.data.members["user456"] does not exist
     * @principle Enforces shared access through inheritance from the parent project's membership map.
     */
    match /projects/{projectId}/tasks/{taskId} {
      // Helper function to get the project document.
      function getProject() {
        return get(/databases/$(database)/documents/projects/$(projectId));
      }

      // Helper function to check if the user is a member of the parent project.
      function isProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }
      
      // Helper function to check if the user is an existing member of the parent project.
      function isExistingProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }

      // Allow creating a task if the user is a member of the project.
      allow create: if isProjectMember();

      // Allow reading a task if the user is a member of the project.
      allow get: if isProjectMember();

      // Allow updating a task if the user is a member of the project.
      allow update: if isProjectMember();

      // Allow deleting a task if the user is an owner of the project.
      allow delete: if isProjectMember();

      // Allow listing tasks if the user is a member of the project.
      allow list: if isProjectMember();
    }

    /**
     * @description Secure chats within a project. Access is inherited from the parent project's 'members' map.
     * @path /projects/{projectId}/chats/{chatId}
     * @allow (create) - Authenticated user creating a chat in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (get) - Authenticated user reading a chat in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (update) - Authenticated user updating a chat in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "editor"
     * @allow (delete) - Authenticated user deleting a chat in a project they own.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "owner"
     * @deny (create) - Unauthenticated user attempting to create a chat.
     *   Request: auth.uid = null
     * @deny (get) - User attempting to read a chat in a project they are not a member of.
     *   Request: auth.uid = "user456", project.data.members["user456"] does not exist
     * @principle Enforces shared access through inheritance from the parent project's membership map.
     */
    match /projects/{projectId}/chats/{chatId} {
      // Helper function to get the project document.
      function getProject() {
        return get(/databases/$(database)/documents/projects/$(projectId));
      }

      // Helper function to check if the user is a member of the parent project.
      function isProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }
      
      // Helper function to check if the user is an existing member of the parent project.
      function isExistingProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }

      // Allow creating a chat if the user is a member of the project.
      allow create: if isProjectMember();

      // Allow reading a chat if the user is a member of the project.
      allow get: if isProjectMember();

      // Allow updating a chat if the user is a member of the project.
      allow update: if isProjectMember();

      // Allow deleting a chat if the user is an owner of the project.
      allow delete: if isProjectMember();

      // Allow listing chats if the user is a member of the project.
      allow list: if isProjectMember();
    }

    /**
     * @description Secure messages within a chat. Access is inherited from the parent project's 'members' map.
     * @path /projects/{projectId}/chats/{chatId}/messages/{messageId}
     * @allow (create) - Authenticated user creating a message in a chat they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (get) - Authenticated user reading a message in a chat they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (update) - Authenticated user updating a message in a chat they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "editor"
     * @allow (delete) - Authenticated user deleting a message in a chat they own.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "owner"
     * @deny (create) - Unauthenticated user attempting to create a message.
     *   Request: auth.uid = null
     * @deny (get) - User attempting to read a message in a chat they are not a member of.
     *   Request: auth.uid = "user456", project.data.members["user456"] does not exist
     * @principle Enforces shared access through inheritance from the parent project's membership map.
     */
    match /projects/{projectId}/chats/{chatId}/messages/{messageId} {
      // Helper function to get the project document.
      function getProject() {
        return get(/databases/$(database)/documents/projects/$(projectId));
      }

      // Helper function to check if the user is a member of the parent project.
      function isProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }
      
      // Helper function to check if the user is an existing member of the parent project.
      function isExistingProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }

      // Allow creating a message if the user is a member of the project.
      allow create: if isProjectMember();

      // Allow reading a message if the user is a member of the project.
      allow get: if isProjectMember();

      // Allow updating a message if the user is a member of the project.
      allow update: if isProjectMember();

      // Allow deleting a message if the user is an owner of the project.
      allow delete: if isProjectMember();

      // Allow listing messages if the user is a member of the project.
      allow list: if isProjectMember();
    }

    /**
     * @description Secure files within a project. Access is inherited from the parent project's 'members' map.
     * @path /projects/{projectId}/files/{fileId}
     * @allow (create) - Authenticated user creating a file in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (get) - Authenticated user reading a file in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] exists
     * @allow (update) - Authenticated user updating a file in a project they are a member of.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "editor"
     * @allow (delete) - Authenticated user deleting a file in a project they own.
     *   Request: auth.uid = "user123", project.data.members["user123"] == "owner"
     * @deny (create) - Unauthenticated user attempting to create a file.
     *   Request: auth.uid = null
     * @deny (get) - User attempting to read a file in a project they are not a member of.
     *   Request: auth.uid = "user456", project.data.members["user456"] does not exist
     * @principle Enforces shared access through inheritance from the parent project's membership map.
     */
    match /projects/{projectId}/files/{fileId} {
      // Helper function to get the project document.
      function getProject() {
        return get(/databases/$(database)/documents/projects/$(projectId));
      }

      // Helper function to check if the user is a member of the parent project.
      function isProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }
      
      // Helper function to check if the user is an existing member of the parent project.
      function isExistingProjectMember() {
        return request.auth != null && getProject().data.members[request.auth.uid] != null;
      }

      // Allow creating a file if the user is a member of the project.
      allow create: if isProjectMember();

      // Allow reading a file if the user is a member of the project.
      allow get: if isProjectMember();

      // Allow updating a file if the user is a member of the project.
      allow update: if isProjectMember();

      // Allow deleting a file if the user is an owner of the project.
      allow delete: if isProjectMember();

      // Allow listing files if the user is a member of the project.
      allow list: if isProjectMember();
    }
  }
}