
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }

    function isParticipant(chatId) {
      return isSignedIn() &&
             request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId))
                 .data.participants;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── USERS COLLECTION ──────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }
    
    // ── CLIENTS COLLECTION ───────────────────────────────────
    match /clients/{clientId} {
      allow get: if isAdmin() || isOwner(clientId);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /clientDocuments/{documentId} {
      allow read: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow create: if isAdmin() || request.resource.data.clientId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /client-packages/{packageId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && 
                    (isAdmin() || resource.data.clientId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── CHATS COLLECTION (Support) ───────────────────────────
    match /chats/{chatId} {
      allow list: if isSignedIn() && request.auth.uid in request.query.where.participants;
      allow get: if isParticipant(chatId);
      allow create: if isAdmin() &&
                       request.resource.data.createdBy == request.auth.uid &&
                       request.auth.uid in request.resource.data.participants;
      allow update: if isParticipant(chatId) &&
                       (
                         !('participants' in request.resource.data) ||
                         isAdmin()
                       );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, list: if isParticipant(chatId);
        allow create: if isParticipant(chatId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(chatId) &&
                         (
                          (
                            resource.data.senderId == request.auth.uid &&
                            request.resource.data.diff(resource.data).affectedKeys()
                                .hasOnly(['deleted', 'readBy', 'pinned', 'text', 'edited', 'editedAt', 'reactions'])
                           ) || 
                           (
                             request.resource.data.diff(resource.data).affectedKeys()
                                .hasOnly(['readBy', 'reactions', 'pinned'])
                           )
                         );
        allow delete: if request.time > timestamp.date(2020, 9, 10);
      }

      match /readReceipts/{userId} {
        allow read: if isParticipant(chatId);
        allow write: if isParticipant(chatId) && isOwner(userId);
      }
    }


    // ── PROJECTS COLLECTION ───────────────────────────────────
    match /projects/{projectId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() &&
                 (
                   isAdmin() ||
                   resource.data.client.id == request.auth.uid ||
                   request.auth.uid in resource.data.team_ids
                 );
      allow create: if isSignedIn() &&
                    (
                      isAdmin() ||
                      request.resource.data.client.id == request.auth.uid
                    );
      allow update: if isSignedIn() &&
                    (
                      isAdmin() ||
                      request.auth.uid in resource.data.team_ids
                    );
      allow delete: if isAdmin();

      // ── PROJECT CHAT SUBCOLLECTION ──────────────────────────
      match /chat-messages/{messageId} {
        function isProjectParticipant() {
          let projectData = get(/databases/$(database)/documents/projects/$(projectId)).data;
          return isAdmin() ||
                 request.auth.uid in projectData.team_ids ||
                 request.auth.uid == projectData.client.id;
        }
        
        allow read, list: if isSignedIn() && isProjectParticipant();
        
        allow create: if isSignedIn() && isProjectParticipant() &&
                         request.resource.data.senderId == request.auth.uid &&
                         (isAdmin() || getUserData().role == 'client');
        
        allow update: if isSignedIn() && isProjectParticipant() &&
                         request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['readBy', 'reactions']);
        
        allow delete: if isAdmin();
      }
    }


    // ── OTHER COLLECTIONS ───────────────────────────────────
    match /tasks/{taskId} {
      allow read, write: if isSignedIn() &&
                         (
                           isAdmin() ||
                           get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.client.id == request.auth.uid ||
                           request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.team_ids
                         );
    }

    match /files/{fileId} {
      allow list: if isAdmin();
      allow get, write: if isSignedIn() &&
                         (
                           isAdmin() ||
                           get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.client.id == request.auth.uid ||
                           request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.team_ids
                         );
    }

    match /scrum-updates/{updateId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn() &&
                    request.resource.data.userId == request.auth.uid;
    }
    
    match /timer-sessions/{sessionId} {
      allow list:   if isSignedIn();
      allow get:    if isSignedIn() && 
                       (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
                       (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() &&
                          request.auth.uid in resource.data.recipients;
    }

    match /calls/{callId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && 
                     (resource.data.callerId == request.auth.uid ||
                      resource.data.recipientId == request.auth.uid);
      allow update: if isSignedIn() &&
                       (resource.data.callerId == request.auth.uid ||
                        resource.data.recipientId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
